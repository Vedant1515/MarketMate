# -------------------------------------------------------------------
# MarketMate - Backend Environment Variables
# Copy this file to .env and fill in your values.
# -------------------------------------------------------------------

# Required: your Anthropic API key (https://console.anthropic.com)
ANTHROPIC_API_KEY=your_claude_key_here

# LLM configuration
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6

# ChromaDB storage path (relative to backend/)
CHROMA_PERSIST_DIR=./chroma_db

# Sales data path (relative to backend/)
SALES_DATA_PATH=./data/produce_sales.csv

# Demo mode: true = use pre-written responses (no API cost)
# Can be toggled at runtime via the UI toggle without restarting.
DEMO_MODE=true

# CORS allowed origins (comma-separated or JSON list)
CORS_ORIGINS=http://localhost:5173

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
